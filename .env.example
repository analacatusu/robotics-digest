# Copy this file to .env and fill in your values.
# Do NOT commit .env to git — it contains live credentials.

# Telegram bot token — ask Ana, or create your own via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Telegram chat ID
# Personal chat: a positive number (get via: python -c "from telegram_bot import get_chat_id; get_chat_id('TOKEN')")
# Group chat:    a negative number (e.g. -1001234567890) — ask Ana for the team group ID
TELEGRAM_CHAT_ID=

# (Optional) Full path to claude.exe if 'claude' is not on your PATH.
# Usually NOT needed — auto-detected via PATH after Claude Code is installed.
# Uncomment and set only if you get "claude CLI not found" errors.
# CLAUDE_BIN=C:\Users\yourname\.local\bin\claude.exe
